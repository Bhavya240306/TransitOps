# Server
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=transitops
DB_USER=root
DB_PASSWORD=Mysql@1110


# Auth
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=24h

# Bonus features - keep false until core is working
ENABLE_EMAIL=false
SMTP_USER=
SMTP_PASS=

# Google Maps (required for live GPS + navigation)
GOOGLE_MAPS_API_KEY=
